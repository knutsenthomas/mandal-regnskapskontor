<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteRule ^(mandal-regnskapskontor-config|one-config)\.php$ - [F,L,NC]
  RewriteRule ^api/(_bootstrap|mandal-regnskapskontor-config|one-config)\.php$ - [F,L,NC]
  RewriteRule ^api/(send-contact|invite-admin|remove-admin)$ api/$1.php [L,QSA,NC]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Do not cache SPA HTML aggressively.
  # Vite rewrites index.html to hashed asset filenames, and stale HTML can point
  # to CSS/JS files that no longer exist after a deploy.
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  
  # Cache hashed build assets in browser/CDN
  <If "%{REQUEST_URI} =~ m#^/assets/.*$#">
    Header set Cache-Control "public, s-maxage=604800, max-age=604800, immutable"
  </If>

  <If "%{REQUEST_URI} =~ m#^/api/.*$#">
    Header set Cache-Control "no-store"
  </If>
</IfModule>
